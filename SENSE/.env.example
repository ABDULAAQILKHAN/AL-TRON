# AL-TRON NestJS gateway. Use your machine's LAN IP, not "localhost" -
# a physical/emulated device can't reach your dev machine's loopback address.
EXPO_PUBLIC_BACKEND_URL=http://192.168.1.19:3000/ai/prompt

# Temporary stand-in until real AUTH-PRO login is wired into the app.
EXPO_PUBLIC_MOCK_AUTH_TOKEN=mock-dev-token

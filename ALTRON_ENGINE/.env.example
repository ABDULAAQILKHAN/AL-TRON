# --- App ---
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Database (Prisma) ---
# DB columns are snake_case; Prisma maps them to camelCase for the app (see prisma/schema.prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/al_tron?schema=public"

# --- Memory layer (Prisma, separate MongoDB datasource - see prisma/mongo/schema.prisma) ---
# Needs Atlas specifically (not just any MongoDB), since retrieval relies on
# Atlas Vector Search over the `memories` collection.
MONGO_DB_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/al_tron_memory?retryWrites=true&w=majority"
MEMORY_VECTOR_SEARCH_INDEX=memory_vector_index

# --- AUTH-PRO microservice ---
AUTH_PRO_BASE_URL=https://p01--auth-pro--f2ksfrkf9d45.code.run/
AUTH_PRO_TIMEOUT_MS=5000
# Note: admin endpoints (/users/ban, /mail/send-custom) take `adminPass` in the
# request body per the AUTH-PRO contract — the caller supplies it, the gateway
# does not need its own copy of the secret.

# --- GitHub Models (router + specialist LLMs, and embeddings for memory) ---
# Needs a GitHub PAT with the "models: read" permission - https://github.com/settings/tokens
GITHUB_PAT=
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
GITHUB_MODELS_DEFAULT_MODEL=openai/gpt-4o-mini
GITHUB_MODELS_EMBEDDING_MODEL=openai/text-embedding-3-small
GITHUB_MODELS_ROUTER_MODEL=openai/gpt-4o-mini
GITHUB_MODELS_SPECIALIST_MODEL=openai/gpt-4o
GITHUB_MODELS_TIMEOUT_MS=30000

# --- Throttling ---
THROTTLE_DEFAULT_TTL_MS=60000
THROTTLE_DEFAULT_LIMIT=100
THROTTLE_AI_TTL_MS=60000
THROTTLE_AI_LIMIT=10

# --- Redis (short-term persona/session state - Phase 2) ---
REDIS_URL=redis://localhost:6379
# How long a session's persona/history state survives with no activity.
PERSONA_SESSION_TTL_SECONDS=21600

# --- Hume AI Voice (Octave TTS) ---
# Get this from https://platform.hume.ai/ -> API Keys. Lives here (server-side)
# rather than in the SENSE app so the key never ships inside the mobile bundle.
HUME_API_KEY=
